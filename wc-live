# ============ 比赛列表 ============

def fetch_todays_matches() -> list[dict]:
    """从直播吧首页提取所有比赛"""
    url = "https://www.zhibo8.com/"
    resp = requests.get(url, headers=HEADERS, timeout=15)
    resp.encoding = "utf-8"
    soup = BeautifulSoup(resp.text, "lxml")

    matches = []
    all_lis = soup.find_all("li", id=re.compile(r"^saishi\d+$"))

    for li in all_lis:
        li_id = li.get("id", "")
        saishi_m = re.search(r"saishi(\d+)", li_id)
        if not saishi_m:
            continue
        saishi_id = saishi_m.group(1)

        # 时间
        time_tag = li.find("time")
        match_time = time_tag.get_text(strip=True) if time_tag else ""

        # 联赛
        league = ""
        league_span = li.find("span", class_="_league")
        if league_span:
            league = league_span.get_text(strip=True)

        # 队伍名
        home_team = ""
        away_team = ""
        teams_span = li.find("span", class_="_teams")
        if teams_span:
            texts = []
            for child in teams_span.children:
                if child.name is None:
                    t = str(child).strip()
                    if t and t != "\n":
                        texts.append(t)
                elif child.name == "span":
                    sep = child.get_text(strip=True)
                    if sep in ("-", "vs"):
                        texts.append("_SEP_")
            full = " ".join(texts)
            parts = full.split("_SEP_")
            if len(parts) >= 2:
                home_team = parts[0].strip()
                away_team = parts[-1].strip()

        # 是否有文字直播
        has_text_live = bool(li.find("a", string=re.compile(r"^文字$")))

        # 世界杯标签
        label = li.get("label", "")
        is_worldcup = "世界杯" in league or "世界杯" in label

        matches.append({
            "saishi_id": saishi_id,
            "match_time": match_time,
            "home_team": home_team or "?",
            "away_team": away_team or "?",
            "score": "",
            "league": "🌍 世界杯" if is_worldcup else league,
            "has_text_live": has_text_live,
        })

    return matches


def show_match_list():
    """显示比赛列表"""
    console.print("[bold green]📋 正在获取比赛列表...[/bold green]")
    matches = fetch_todays_matches()

    if not matches:
        console.print("[yellow]⚠️ 未获取到数据，可能是网络或反爬限制[/yellow]")
        return

    # 只显示有文字直播的
    text_matches = [m for m in matches if m["has_text_live"]]

    table = Table(
        title="🎯 [bold]直播吧 — 文字直播比赛列表[/bold]",
        box=box.ROUNDED,
        border_style="green",
        header_style="bold white",
        show_lines=True,
    )
    table.add_column("#", style="dim", width=4)
    table.add_column("时间", style="cyan", width=6)
    table.add_column("赛事", style="dim", width=16)
    table.add_column("主队", style="bold cyan", width=20)
    table.add_column("客队", style="bold magenta", width=20)

    # 世界杯排前面
    wc = [m for m in text_matches if "世界杯" in m["league"]]
    other = [m for m in text_matches if "世界杯" not in m["league"]]

    idx = 0
    for m in wc + other:
        idx += 1
        table.add_row(
            str(idx),
            m["match_time"],
            m["league"],
            m["home_team"],
            m["away_team"],
        )

    console.print(table)
    console.print(f"\n[dim]共 {idx} 场比赛支持文字直播。运行 [bold]wc-live <序号>[/bold] 进入直播[/dim]")


