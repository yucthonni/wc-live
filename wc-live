# ============ 文字直播模式 ============

def live_mode(saishi_id: str):
    """进入文字直播模式"""
    # 找服务器
    console.print("[dim]📡 连接直播服务器...[/dim]")
    server = _find_server(saishi_id)
    if not server:
        console.print("[red]❌ 无法连接直播服务器[/red]")
        return

    # 获取比赛信息
    info = fetch_match_page(saishi_id)
    home_team = info.get("home_team", "?")
    away_team = info.get("away_team", "?")

    # 获取比赛状态
    match_status = get_match_status(saishi_id, server)

    console.clear()

    # 打印头部（含状态）
    status_style = {
        "live": "bold red",
        "halftime": "bold yellow",
        "finished": "dim",
        "not_started": "bold cyan",
    }.get(match_status["status"], "dim")
    
    header = Panel(
        Text.assemble(
            (f"{home_team} ", "bold cyan"),
            ("vs ", "yellow bold"),
            (f"{away_team}", "bold magenta"),
            ("\n", ""),
            (f"📅 {info.get('match_time','')} | ", "dim"),
            (f"🆔 {saishi_id}", "dim"),
            (f"\n{match_status['status_text']}", status_style),
            (f" {match_status['score']}" if match_status['score'] else "", "bold"),
            (f" | {match_status['period']}" if match_status['period'] else "", "dim"),
        ),
        title="🎯 文字直播",
        border_style="green",
        box=box.DOUBLE,
    )
    console.print(header)

    # 如果比赛未开始或已结束，提示用户
    if match_status["status"] == "not_started":
        console.print("\n[yellow]⏳ 比赛尚未开始，等待中...[/yellow]")
        console.print("[dim]将自动检测比赛开始，按 Ctrl+C 退出[/dim]\n")
    elif match_status["status"] == "finished":
        console.print("\n[yellow]🏁 比赛已结束，显示历史记录[/yellow]\n")
    elif match_status["status"] == "halftime":
        console.print("\n[yellow]⏸️ 中场休息中...[/yellow]")
        console.print("[dim]将自动检测下半场比赛开始[/dim]\n")

    # 初始加载（只加载最近几页，不从第0页开始）
    seen_ids = set()
    all_entries = []
    last_sid = 0

    try:
        last_sid = get_max_sid(saishi_id, server)
        # 只加载最近20页，避免初始加载太慢
        start_sid = max(0, last_sid - 20)
        for sid in range(start_sid, last_sid + 1):
            entries = get_live_texts(saishi_id, sid, server)
            for e in entries:
                if e.live_id not in seen_ids:
                    seen_ids.add(e.live_id)
                    all_entries.append(e)
                    # 每条实时打印，不等加载完
                    console.print(format_live_text(e))
            time.sleep(random.uniform(0.1, 0.2))

        console.print(f"\n[dim]已加载 {len(all_entries)} 条，进入自动刷新模式 (按 Ctrl+C 退出)[/dim]\n")

        # 轮询
        while True:
            time.sleep(5 + random.uniform(0, 2))

            current_max = get_max_sid(saishi_id, server)
            if current_max > last_sid:
                new_count = 0
                for sid in range(last_sid + 1, current_max + 1):
                    entries = get_live_texts(saishi_id, sid, server)
                    for e in entries:
                        if e.live_id not in seen_ids:
                            seen_ids.add(e.live_id)
                            all_entries.append(e)
                            console.print(format_live_text(e))
                            new_count += 1
                    time.sleep(random.uniform(0.1, 0.3))

                if new_count > 0:
                    now = datetime.now().strftime("%H:%M:%S")
                    console.print(f"[dim]— {now} · 新增 {new_count} 条 —[/dim]")

                last_sid = current_max

    except KeyboardInterrupt:
        console.print("\n\n[dim]⏹  直播已退出[/dim]")
        console.print(f"[dim]本场共加载 {len(all_entries)} 条文字直播[/dim]")


# ============ 入口 ============

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        return

    # Debug 模式
    if args[0] in ("debug", "-d"):
        if len(args) < 2:
            console.print("[red]❌ 用法: wc-live debug <序号|saishi_id>[/red]")
            return
        target = args[1]
        if target.isdigit():
            if len(target) > 5:
                debug_mode(target)
            else:
                matches = fetch_todays_matches()
                text_matches = [m for m in matches if m.get("has_text_live")]
                idx = int(target) - 1
                if 0 <= idx < len(text_matches):
                    debug_mode(text_matches[idx]["saishi_id"])
                else:
                    console.print(f"[red]❌ 序号 {target} 超出范围[/red]")
        else:
            m = re.search(r"match(\d+)v\.htm", target)
            if m:
                debug_mode(m.group(1))
            else:
                console.print(f"[red]❌ 无效参数: {target}[/red]")
        return

    # 极简模式
    if args[0] in ("stealth", "-s"):
        if len(args) < 2:
            console.print("[red]❌ 用法: wc-live stealth <序号|saishi_id>[/red]")
            return
        target = args[1]
        if target.isdigit():
            if len(target) > 5:
                stealth_mode(target)
            else:
                matches = fetch_todays_matches()
                text_matches = [m for m in matches if m.get("has_text_live")]
                idx = int(target) - 1
                if 0 <= idx < len(text_matches):
                    stealth_mode(text_matches[idx]["saishi_id"])
                else:
                    console.print(f"[red]❌ 序号 {target} 超出范围[/red]")
        else:
            m = re.search(r"match(\d+)v\.htm", target)
            if m:
                stealth_mode(m.group(1))
            else:
                console.print(f"[red]❌ 无效参数: {target}[/red]")
        return

    if args[0] == "list":
        show_match_list()
        return

    arg = args[0]

    if arg.isdigit():
        if len(arg) > 5:
            live_mode(arg)
        else:
            matches = fetch_todays_matches()
            text_matches = [m for m in matches if m.get("has_text_live")]
            idx = int(arg) - 1
            if 0 <= idx < len(text_matches):
                live_mode(text_matches[idx]["saishi_id"])
            else:
                console.print(f"[red]❌ 序号 {arg} 超出范围 (共 {len(text_matches)} 场)[/red]")
                console.print("[dim]运行 'wc-live list' 查看比赛列表[/dim]")
    else:
        if arg.startswith("match") and arg.endswith("v.htm"):
            m = re.search(r"match(\d+)v\.htm", arg)
            if m:
                live_mode(m.group(1))
                return
        console.print(f"[red]❌ 无效参数: {arg}[/red]")
        print(__doc__)


if __name__ == "__main__":
    main()
