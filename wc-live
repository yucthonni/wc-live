# ============ 极简模式 ============

def stealth_mode(saishi_id: str):
    """极简单行模式 — 只有一行文字在终端里覆盖更新，绝对隐蔽"""
    server = _find_server(saishi_id)
    if not server:
        console.print("[red]❌ 无法连接直播服务器[/red]")
        return

    info = fetch_match_page(saishi_id)
    home_team = info.get("home_team", "?")
    away_team = info.get("away_team", "?")

    # 获取比赛状态
    match_status = get_match_status(saishi_id, server)
    status_emoji = {
        "live": "🔴",
        "halftime": "⏸️",
        "finished": "🏁",
        "not_started": "⏳",
    }.get(match_status["status"], "❓")
    
    # 进场时闪一下比赛信息，马上消失
    status_text = f"{status_emoji} {match_status['status_text']}"
    if match_status['score']:
        status_text += f" {match_status['score']}"
    sys.stdout.write(f"\r\033[K[wc] {home_team} vs {away_team} | {status_text}")
    sys.stdout.flush()
    time.sleep(2)

    seen_ids = set()
    last_text = ""
    last_sid = 0

    try:
        # 初始加载（只加载最近几页）
        last_sid = get_max_sid(saishi_id, server)
        all_init = []
        start_sid = max(0, last_sid - 20)
        for sid in range(start_sid, last_sid + 1):
            entries = get_live_texts(saishi_id, sid, server)
            for e in entries:
                if e.live_id not in seen_ids:
                    seen_ids.add(e.live_id)
                    all_init.append(e)
            time.sleep(random.uniform(0.05, 0.1))

        # 取最新的显示
        if all_init:
            all_init.sort(key=lambda x: x.live_sid)
            last_text = _format_stealth(all_init[-1])

        while True:
            time.sleep(5 + random.uniform(0, 2))
            current_max = get_max_sid(saishi_id, server)
            if current_max > last_sid:
                for sid in range(last_sid + 1, current_max + 1):
                    entries = get_live_texts(saishi_id, sid, server)
                    for e in entries:
                        if e.live_id not in seen_ids:
                            seen_ids.add(e.live_id)
                            last_text = _format_stealth(e)
                    time.sleep(random.uniform(0.05, 0.1))
                last_sid = current_max

            # 单行覆盖
            if last_text:
                sys.stdout.write(f"\r\033[K{last_text}")
            else:
                now = datetime.now().strftime("%H:%M")
                sys.stdout.write(f"\r\033[K[{now}] ⏳ 等待比赛更新...")
            sys.stdout.flush()

    except KeyboardInterrupt:
        sys.stdout.write(f"\r\033[K[wc] 直播退出\033[K\n")
        sys.stdout.flush()


def _format_stealth(entry: LiveTextEntry) -> str:
    """极简单行格式 — 干净、紧凑"""
    icon = ""
    if entry.event:
        if "goal" in entry.event:
            icon = "⚽"
        elif "red" in entry.event:
            icon = "🟥"
        elif "yellow" in entry.event:
            icon = "🟨"

    time_str = entry.live_time[-5:] if len(entry.live_time) >= 5 else ""

    text = entry.live_text.strip()
    # 截短过长内容
    if len(text) > 80:
        text = text[:77] + "..."

    score = ""
    if entry.home_score or entry.visit_score:
        score = f" {entry.home_score or '0'}-{entry.visit_score or '0'}"

    return f"[{time_str}]{icon}{score} {text}"


